# ─────────────────────────────────────────────────────────────────
# ECommerceSystem — Environment Variables Template
#
# Bu dosyayı kopyalayın: cp .env.example .env
# Ardından .env içindeki değerleri kendi ortamınıza göre düzenleyin.
# .env dosyası GIT'E GÖNDERILMEZ (.gitignore'a ekleyin).
# ─────────────────────────────────────────────────────────────────

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=productdb

# ─── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=changeme
